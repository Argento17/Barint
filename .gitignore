# Python virtualenv (658M — never track)
.venv/

# Python caches
__pycache__/
*.pyc
*.pyo

# Secrets / local env (never track). Covers .env, .env.local, .env.production,
# .env.*.local, etc. — every variant except the safe-to-track .env.example.
.env
.env.*
!.env.example

# Personal credentials — Google Workspace (Gmail/Calendar) connector for CC.
# The real token lives at ~/.bari/google_token.json (outside the repo). These
# patterns guard against any in-repo override or a downloaded Google client
# secret ever being committed. NEVER push these.
.bari/
google_token.json
*client_secret*.json
*client-secret*.json

# IDE
.idea/

# Local-only Claude settings — agents/skills/hooks ARE tracked, local prefs are not
.claude/settings.local.json

# Derived backups / scratch (use 99_archive for anything worth keeping)
*.audit_bak
/tmp_*

# OS
Thumbs.db
.DS_Store

# Local archive of agent transcripts + repo backup (350 MB, secret-bearing).
# Physically lives in C:\Bari but is NEVER pushed to the public remote.
# Only archive/README.md is tracked, as a committed pointer to what's here.
/archive/*
!/archive/README.md
